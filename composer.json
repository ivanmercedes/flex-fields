{
    "name": "ivanmercedes/flex-fields",
    "description": "ACF-like Custom Entities & Custom Fields plugin for Laravel + Filament",
    "type": "library",
    "require": {
        "filament/filament": "^4.0|^5.0",
        "php": "^8.1|^8.2|^8.3"
    },
    "autoload": {
        "psr-4": {
            "IvanMercedes\\FlexFields\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanMercedes\\FlexFields\\FlexFieldsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
