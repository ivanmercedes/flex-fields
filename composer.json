{
    "name": "ivanmercedes/flex-fields",
    "description": "ACF-like Custom Entities & Custom Fields plugin for Laravel + Filament",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "custom-fields",
        "entities"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ivan Mercedes",
            "email": "ivanmercede@gmail.com"
        }
    ],
    "scripts": {
        "cs": [
            "pint --parallel"
        ]
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "laravel/prompts": "^0.1.18|^0.2.0|^0.3.0"
    },
    "autoload": {
        "psr-4": {
            "IvanMercedes\\FlexFields\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IvanMercedes\\FlexFields\\FlexFieldsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "laravel/pint": "^1.29"
    }
}
